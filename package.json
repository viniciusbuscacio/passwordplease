{
  "name": "passwordplease",
  "productName": "passwordPlease",
  "version": "2.0.0",
  "description": "A secure password manager with Clean Architecture",
  "main": "out/adapters/electron/main.js",
  "bin": {
    "pp": "out/adapters/cli/cli.js"
  },
  "scripts": {
    "build": "tsc && tsc -p src/adapters/electron/tsconfig.renderer.json && node copy-assets.js",
    "start": "npm run build && electron .",
    "test": "npm rebuild better-sqlite3 && tsx --test tests/**/*.test.ts",
    "build:mac": "npm run build && electron-builder --mac --arm64",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "postinstall": "node post-build.js"
  },
  "build": {
    "appId": "com.buscacio.passwordplease",
    "productName": "passwordPlease",
    "files": [
      "out/**/*",
      "build/**/*",
      "libs/**/*",
      "images/**/*",
      "!**/*.test.js",
      "!**/*.test.ts",
      "!tests/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "darkModeSupport": true
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/viniciusbuscacio/passwordplease.git"
  },
  "keywords": [
    "password",
    "manager",
    "electron",
    "security",
    "encryption"
  ],
  "author": "Vinicius Buscacio",
  "license": "CC0-1.0",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "better-sqlite3": "^12.9.0",
    "bootstrap-icons": "^1.10.5",
    "uuid": "^9.0.0"
  },
  "bugs": {
    "url": "https://github.com/viniciusbuscacio/passwordplease/issues"
  },
  "homepage": "https://github.com/viniciusbuscacio/passwordplease#readme"
}